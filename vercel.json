{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://mili-course-ai-backend.onrender.com/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://mili-course-ai-backend.onrender.com/:path*"
    },
    {
      "source": "/((?!api/|auth/).*)",
      "destination": "/index.html"
    }
  ]
}
